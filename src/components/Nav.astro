---
import { site } from "@/data/site";

const { pathname } = Astro.url;
---

<nav class="w-full border-t-2 border-accent/70" aria-label="Site navigation">
  <!-- ── Wordmark ────────────────────────────────────────────────────────── -->
  <div class="px-[clamp(1rem,5vw,3rem)] py-5 text-center">
    <a
      href="/"
      class="inline-block font-display italic font-light text-[clamp(2.8rem,8vw,5.5rem)] tracking-[-0.025em] leading-none text-ink no-underline transition-colors duration-[160ms] hover:text-accent"
      aria-label={site.nav.homeLabel}
    >
      {site.name}
    </a>
  </div>

  <div class="border-t border-accent/25"></div>

  <!-- ── Section links ──────────────────────────────────────────────────── -->
  <div
    class="px-[clamp(1rem,5vw,3rem)] flex items-center gap-8 border-b border-accent/25"
  >
    {
      site.nav.sections.map(({ label, href }) => {
        const isAnchor = href.startsWith("/#");
        const active = isAnchor ? false : pathname.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              "font-body text-sm tracking-[0.14em] uppercase transition-colors duration-[160ms] py-2.5",
              active
                ? "text-ink border-b-2 border-accent -mb-px font-semibold"
                : "text-muted hover:text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {label}
          </a>
        );
      })
    }
  </div>
</nav>
