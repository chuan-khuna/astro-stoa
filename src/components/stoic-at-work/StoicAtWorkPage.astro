---
import Centre from "@/components/Centre.astro";
import TableOfContents from "@/components/stoic/sections/TableOfContents.astro";
import Intro from "@/components/stoic-at-work/sections/Intro.astro";
import WorkSection from "@/components/stoic-at-work/sections/WorkSection.astro";
import type { StoicAtWorkContent } from "@/data/stoic-at-work/types";

interface Props {
  content: StoicAtWorkContent;
}

const { content } = Astro.props;
---

<!-- Page header -->
<div class="border-b border-rule">
  <Centre class="pt-12 pb-4">
    <div class="flex items-start justify-between gap-6">
      <div>
        <p
          class="font-body text-sm tracking-[0.14em] uppercase text-muted mb-2"
        >
          {content.header.eyebrow}
        </p>
        <h1
          class="font-display italic text-[clamp(2.4rem,6vw,4.2rem)] leading-none text-ink"
        >
          {content.header.title}
        </h1>
        <p class="font-body text-md text-muted mt-3 max-w-2xl leading-relaxed">
          {content.header.description}
        </p>
      </div>
      <a
        href={content.langSwitch.href}
        class="shrink-0 mt-1 font-body text-xs tracking-[0.12em] uppercase border border-rule px-3 py-1.5 text-muted hover:text-ink hover:border-neutral transition-colors whitespace-nowrap"
      >
        {content.langSwitch.label}
      </a>
    </div>
  </Centre>
</div>

<!-- Table of contents -->
<TableOfContents sections={content.toc} />

<div id="intro">
  <Intro content={content.intro} />
</div>

<div id="fast-brief">
  <WorkSection content={content.fastBrief} />
</div>

<div id="impossible">
  <WorkSection content={content.impossible} />
</div>

<div id="boast">
  <WorkSection content={content.boast} />
</div>

<div id="cost">
  <WorkSection content={content.cost} />
</div>

<div id="recovery">
  <WorkSection content={content.recovery} />
</div>
