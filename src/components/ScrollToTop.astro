<!--
  Pinned 1.5rem inside the right border rail of the 90rem content container.
  On narrow viewports it falls back to 1.5rem from the viewport edge.
  Bottom yields to iOS safe-area-inset (home indicator).
  Touch target: 44×44 on mobile, 36×36 on sm+.
-->
<button
  id="scroll-top"
  aria-label="Scroll to top"
  style="right: max(1.5rem, calc((100vw - 90rem) / 2 + 1.5rem)); bottom: max(2rem, calc(env(safe-area-inset-bottom, 0px) + 1.25rem))"
  class="fixed w-11 h-11 sm:w-9 sm:h-9 flex items-center justify-center border border-ink text-ink opacity-0 pointer-events-none transition-opacity duration-300 hover:bg-ink hover:text-paper bg-paper focus-visible:opacity-100"
>
  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
    <path d="M6 10V2M2 6l4-4 4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('scroll-top');
  if (btn) {
    const show = () => {
      const visible = window.scrollY > 400;
      btn.style.opacity = visible ? '1' : '0';
      btn.style.pointerEvents = visible ? 'auto' : 'none';
    };
    window.addEventListener('scroll', show, { passive: true });
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>
