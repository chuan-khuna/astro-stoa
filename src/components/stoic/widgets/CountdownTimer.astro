---
interface Props {
  seconds?: number;
  labelStart?: string;
  labelReset?: string;
  labelDone?: string;
}
const { seconds = 60, labelStart = "Start", labelReset = "Reset", labelDone = "Done" } = Astro.props;

const mm = String(Math.floor(seconds / 60)).padStart(2, "0");
const ss = String(seconds % 60).padStart(2, "0");
---

<div
  class="mt-3 flex items-center gap-4"
  data-countdown
  data-seconds={seconds}
  data-label-start={labelStart}
  data-label-reset={labelReset}
  data-label-done={labelDone}
>
  <p class="font-mono text-2xl text-ink tracking-widest leading-none" data-display>
    {mm}:{ss}
  </p>
  <div class="flex items-center gap-2">
    <div
      data-breath-circle
      class="rounded-full shrink-0"
      style="width:0.5rem;height:0.5rem;background-color:transparent;transform:scale(1);transition:transform 0.5s ease,background-color 0.5s ease"
    ></div>
    <p
      data-breath-label
      class="font-body text-sm tracking-[0.12em] uppercase transition-colors duration-500"
      style="color:transparent"
    >&nbsp;</p>
  </div>
  <button
    class="font-body text-xs tracking-[0.12em] uppercase border border-rule px-3 py-1.5 text-muted hover:text-ink hover:border-neutral transition-colors"
    data-btn
  >
    {labelStart}
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-countdown]").forEach((el) => {
    const total = Number(el.dataset.seconds);
    const lblStart = el.dataset.labelStart ?? "Start";
    const lblReset = el.dataset.labelReset ?? "Reset";
    const lblDone  = el.dataset.labelDone  ?? "Done";
    const display = el.querySelector<HTMLElement>("[data-display]")!;
    const btn    = el.querySelector<HTMLButtonElement>("[data-btn]")!;
    const circle = el.querySelector<HTMLElement>("[data-breath-circle]")!;
    const label  = el.querySelector<HTMLElement>("[data-breath-label]")!;

    let remaining = total;
    let timerInterval: ReturnType<typeof setInterval> | null = null;
    let breathInterval: ReturnType<typeof setInterval> | null = null;
    let phaseIndex = 0;
    let phaseRemaining = 0;

    const PHASES = [
      { name: "Inhale", duration: 4, scale: "1.45", color: "rgba(96,165,250,0.8)"  },
      { name: "Hold",   duration: 7, scale: "1.45", color: "rgba(251,191,36,0.85)" },
      { name: "Exhale", duration: 8, scale: "0.65", color: "rgba(52,211,153,0.75)" },
    ];

    const fmt = (s: number) =>
      `${String(Math.floor(s / 60)).padStart(2, "0")}:${String(s % 60).padStart(2, "0")}`;

    const applyPhase = (idx: number) => {
      const phase = PHASES[idx];
      const transformDur = idx === 1
        ? "0.4s"
        : `${(phase.duration * 0.9).toFixed(1)}s`;
      circle.style.transition =
        `transform ${transformDur} ease-in-out, background-color 0.45s ease`;
      circle.style.transform = `scale(${phase.scale})`;
      circle.style.backgroundColor = phase.color;
      label.style.color = phase.color;
      label.textContent = phase.name;
    };

    const stopBreathing = () => {
      clearInterval(breathInterval!);
      breathInterval = null;
      circle.style.transition = "transform 0.55s ease, background-color 0.55s ease";
      circle.style.transform = "scale(1)";
      circle.style.backgroundColor = "transparent";
      label.style.color = "transparent";
      label.innerHTML = "&nbsp;";
    };

    const startBreathing = () => {
      phaseIndex = 0;
      phaseRemaining = PHASES[0].duration;
      applyPhase(0);
      breathInterval = setInterval(() => {
        phaseRemaining--;
        if (phaseRemaining <= 0) {
          phaseIndex = (phaseIndex + 1) % PHASES.length;
          phaseRemaining = PHASES[phaseIndex].duration;
          applyPhase(phaseIndex);
        }
      }, 1000);
    };

    const reset = () => {
      clearInterval(timerInterval!);
      timerInterval = null;
      stopBreathing();
      remaining = total;
      display.textContent = fmt(remaining);
      display.classList.remove("text-highlight");
      btn.textContent = lblStart;
    };

    btn.addEventListener("click", () => {
      if (timerInterval) { reset(); return; }
      startBreathing();
      timerInterval = setInterval(() => {
        remaining--;
        display.textContent = fmt(remaining);
        if (remaining <= 0) {
          clearInterval(timerInterval!);
          timerInterval = null;
          stopBreathing();
          display.textContent = lblDone;
          display.classList.add("text-highlight");
          btn.textContent = lblReset;
        }
      }, 1000);
      btn.textContent = lblReset;
    });
  });
</script>
