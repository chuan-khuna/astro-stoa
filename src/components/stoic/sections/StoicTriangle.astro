---
import Centre from "@/components/Centre.astro";
import type { StoicContent } from "@/data/stoic/types";

interface Props {
  content: StoicContent["stoicTriangle"];
}

const { content } = Astro.props;
const { svgLabels: svg, pillars } = content;
---

<section class="border-t border-rule py-16">
  <Centre>

    <div class="max-w-3xl mb-6">
      <h2 class="font-display italic text-[clamp(1.8rem,4vw,2.8rem)] leading-tight text-ink mb-3">
        {content.heading}
      </h2>
      <p class="font-body text-sm tracking-[0.12em] uppercase text-muted mb-6" set:html={content.source} />
      <p class="font-body text-md leading-relaxed text-ink" set:html={content.intro} />
    </div>

    <!-- Triangle diagram -->
    <div class="flex justify-center my-14 select-none" aria-hidden="true">
      <svg
        viewBox="0 0 420 380"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-full max-w-md"
      >
        <polygon
          points="210,48 374,294 46,294"
          stroke="var(--color-accent)"
          stroke-opacity="0.5"
          stroke-width="1.5"
          fill="var(--color-accent)"
          fill-opacity="0.03"
          stroke-linejoin="miter"
        />

        <text x="210" y="28" text-anchor="middle" font-family="var(--font-spectral)" font-style="italic" font-size="13" fill="var(--color-ink)">{svg.topVertex}</text>

        <text x="400" y="318" text-anchor="end" font-family="var(--font-spectral)" font-style="italic" font-size="13" fill="var(--color-ink)">{svg.bottomRightLine1}</text>
        <text x="400" y="338" text-anchor="end" font-family="var(--font-spectral)" font-style="italic" font-size="13" fill="var(--color-ink)">{svg.bottomRightLine2}</text>

        <text x="20" y="318" text-anchor="start" font-family="var(--font-spectral)" font-style="italic" font-size="13" fill="var(--color-ink)">{svg.bottomLeftLine1}</text>
        <text x="20" y="338" text-anchor="start" font-family="var(--font-spectral)" font-style="italic" font-size="13" fill="var(--color-ink)">{svg.bottomLeftLine2}</text>

        <text x="210" y="188" text-anchor="middle" font-family="var(--font-alegreya-sans)" font-size="9" letter-spacing="0.14em" fill="var(--color-muted)" dominant-baseline="middle">{svg.centre}</text>
        <text x="210" y="206" text-anchor="middle" font-family="var(--font-spectral)" font-style="italic" font-size="11" fill="var(--color-muted)" dominant-baseline="middle">{svg.centreItalic}</text>
      </svg>
    </div>

    <!-- Three pillars -->
    <div class="grid grid-cols-1 border-l border-t border-rule">
      {pillars.map(({ number, label, sub, description, virtues, note, quote }) => (
        <div class="border-r border-b border-rule p-7">
          <p class="font-mono text-xs text-muted tracking-wider mb-3">{number}</p>
          <h3 class="font-display italic text-xl text-ink mb-0.5">{label}</h3>
          <p class="font-body text-sm tracking-[0.1em] uppercase text-muted mb-5">{sub}</p>
          <p class="font-body text-md leading-relaxed text-ink mb-5">{description}</p>
          {(virtues ?? []).length > 0 && (
            <ul class="border-l border-rule pl-5 mb-6 space-y-3">
              {(virtues ?? []).map(({ name, detail }) => (
                <li>
                  <p class="font-display italic text-ink text-base leading-tight">{name}</p>
                  <p class="font-body text-sm text-muted mt-0.5 leading-snug">{detail}</p>
                </li>
              ))}
            </ul>
          )}
          {note && (
            <p class="font-body text-sm text-muted leading-relaxed italic mb-5">{note}</p>
          )}
          <blockquote class="font-display italic text-base text-ink leading-snug mb-1">
            "{quote.text}"
          </blockquote>
          <cite class="font-body text-xs tracking-[0.1em] uppercase text-muted not-italic">
            {quote.author}
          </cite>
        </div>
      ))}
    </div>

    <!-- Closing note -->
    <div class="max-w-3xl mt-12 space-y-4">
      <h3 class="font-body text-sm tracking-[0.14em] uppercase text-muted">{content.whyTriangleHeading}</h3>
      {content.whyTriangleParagraphs.map((p) => (
        <p class="font-body text-md leading-relaxed text-ink">{p}</p>
      ))}
    </div>

  </Centre>
</section>
