---
import Centre from "@/components/Centre.astro";
import type { StoicContent } from "@/data/stoic/types";

interface Props {
  content: StoicContent["dichotomy"];
}

const { content } = Astro.props;
---

<section class="border-t border-rule py-16">
  <Centre>
    <div class="max-w-3xl mb-10">
      <h2 class="font-display italic text-[clamp(1.8rem,4vw,2.8rem)] leading-tight text-ink mb-3">
        {content.heading}
      </h2>
      <p class="font-body text-sm tracking-[0.12em] uppercase text-muted mb-8" set:html={content.source} />
      <p class="font-body text-md leading-relaxed text-ink" set:html={content.intro} />
    </div>

    <!-- Two-column control table -->
    <div class="grid grid-cols-1 min-[48rem]:grid-cols-2 border-l border-t border-rule">
      <div class="border-r border-b border-rule p-6">
        <p class="font-body text-sm tracking-[0.14em] uppercase text-muted mb-5">
          {content.inControlLabel}
        </p>
        <ul class="space-y-4">
          {content.inControl.map(({ term, detail }) => (
            <li>
              <p class="font-display italic text-ink text-md leading-tight">{term}</p>
              <p class="font-body text-sm text-muted mt-0.5 leading-snug">{detail}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="border-r border-b border-rule p-6">
        <p class="font-body text-sm tracking-[0.14em] uppercase text-muted mb-5">
          {content.notInControlLabel}
        </p>
        <ul class="space-y-4">
          {content.notInControl.map(({ term, detail }) => (
            <li>
              <p class="font-display italic text-ink text-md leading-tight">{term}</p>
              <p class="font-body text-sm text-muted mt-0.5 leading-snug">{detail}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Practice note -->
    <div class="max-w-3xl mt-10 space-y-4">
      <h3 class="font-body text-sm tracking-[0.14em] uppercase text-muted">
        {content.howToApplyHeading}
      </h3>
      {content.howToApplyParagraphs.map((p) => (
        <p class="font-body text-md leading-relaxed text-ink" set:html={p} />
      ))}
      <div class="border-l-2 border-accent/50 pl-6 py-1 mt-8">
        <blockquote class="font-display italic text-lg text-ink leading-snug mb-2">
          "{content.quote.text}"
        </blockquote>
        <cite class="font-body text-sm tracking-[0.1em] uppercase text-muted not-italic" set:html={content.quote.author} />
      </div>
    </div>
  </Centre>
</section>
