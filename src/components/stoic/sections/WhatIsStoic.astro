---
import Centre from "@/components/Centre.astro";
import type { StoicContent } from "@/data/stoic/types";

interface Props {
  content: StoicContent["whatIsStoic"];
}

const { content } = Astro.props;
---

<section class="py-16">
  <Centre>
    <h2 class="font-display italic text-[clamp(1.8rem,4vw,2.8rem)] leading-tight text-ink mb-6">
      {content.heading}
    </h2>

    {content.paragraphs.map((p) => (
      <p class="font-body text-md leading-relaxed text-ink mb-5" set:html={p} />
    ))}

    <div class="border-l-2 border-accent/50 pl-6 py-1">
      <blockquote class="font-display italic text-lg text-ink leading-snug mb-2">
        "{content.quote.text}"
      </blockquote>
      <cite class="font-body text-sm tracking-[0.1em] uppercase text-muted not-italic" set:html={content.quote.author} />
    </div>
  </Centre>
</section>
