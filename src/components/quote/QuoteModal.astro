---

---

<dialog
  id="quote-modal"
  class="fixed inset-0 m-auto w-full max-w-2xl max-h-[90dvh] overflow-y-auto bg-paper p-[clamp(2rem,6vw,4rem)] open:flex flex-col gap-8"
>
  <button
    id="modal-close"
    aria-label="Close"
    class="absolute top-6 right-6 text-neutral hover:text-ink transition-colors duration-150"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 18 18"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M2 2l14 14M16 2L2 16"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"></path>
    </svg>
  </button>

  <!-- Excerpt as title -->
  <blockquote>
    <span
      aria-hidden="true"
      class="block font-display italic leading-none text-[5rem] text-accent/25 -mb-4 -ml-1 select-none"
      >&ldquo;</span
    >
    <p
      id="modal-excerpt"
      class="font-display italic font-light text-[clamp(1.5rem,3.2vw,2.5rem)] leading-[1.45] text-ink [overflow-wrap:anywhere] min-w-0 [text-wrap:pretty]"
    >
    </p>
  </blockquote>

  <!-- Attribution -->
  <div class="flex flex-col gap-1">
    <cite
      id="modal-author"
      class="block font-body not-italic text-[0.563rem] tracking-[0.14em] uppercase text-muted"
    ></cite>
    <span
      id="modal-source"
      class="block font-display italic text-[0.75rem] text-neutral"></span>
  </div>

  <!-- Full body -->
  <div id="modal-body-wrapper" class="border-t border-rule pt-6">
    <div
      id="modal-body"
      class="prose prose-sm max-w-[65ch]"
    >
    </div>
  </div>
</dialog>

<style>
  /* Exit (closed) state — these are the values the dialog animates toward on close */
  dialog {
    opacity: 0;
    translate: 0 1.75rem;
    transition:
      opacity 220ms cubic-bezier(0.16, 1, 0.3, 1),
      translate 220ms cubic-bezier(0.16, 1, 0.3, 1),
      overlay 220ms allow-discrete,
      display 220ms allow-discrete;
  }

  /* Open state */
  dialog[open] {
    opacity: 1;
    translate: 0 0;
  }

  /* Override the starting point for the open animation */
  @starting-style {
    dialog[open] {
      opacity: 0;
      translate: 0 1.75rem;
    }
  }

  /* Backdrop exit state */
  dialog::backdrop {
    background: var(--color-ink);
    opacity: 0;
    backdrop-filter: blur(0px);
    transition:
      opacity 220ms cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 220ms cubic-bezier(0.16, 1, 0.3, 1),
      overlay 220ms allow-discrete,
      display 220ms allow-discrete;
  }

  dialog[open]::backdrop {
    opacity: 0.35;
    backdrop-filter: blur(6px);
  }

  @starting-style {
    dialog[open]::backdrop {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    dialog,
    dialog::backdrop {
      transition: none;
      backdrop-filter: none;
    }
  }

  /* Tune prose to site tokens */
  #modal-body {
    --tw-prose-body: var(--color-neutral);
    --tw-prose-headings: var(--color-ink);
    --tw-prose-hr: var(--color-rule);
    --tw-prose-bullets: var(--color-neutral);
    --tw-prose-counters: var(--color-neutral);
    --tw-prose-links: var(--color-ink);
    font-family: var(--font-body);
  }
</style>

<script>
  const modal = document.getElementById("quote-modal") as HTMLDialogElement;
  const modalExcerpt = document.getElementById("modal-excerpt")!;
  const modalAuthor = document.getElementById("modal-author")!;
  const modalSource = document.getElementById("modal-source")!;
  const modalBody = document.getElementById("modal-body")!;
  const modalBodyWrapper = document.getElementById("modal-body-wrapper")!;
  const closeBtn = document.getElementById("modal-close")!;

  function openModal(card: HTMLElement) {
    modalExcerpt.textContent = card.dataset.excerpt?.trim() ?? "";
    modalAuthor.textContent = card.dataset.author ?? "";
    modalSource.textContent = card.dataset.source ?? "";

    const hasBody = card.dataset.hasBody === "true";
    if (hasBody) {
      const bodyEl = document.getElementById(`quote-body-${card.dataset.bodyId}`);
      modalBody.innerHTML = bodyEl ? bodyEl.innerHTML : "";
    } else {
      modalBody.innerHTML = "";
    }
    modalBodyWrapper.style.display = hasBody ? "" : "none";

    modal.showModal();
  }

  function closeModal() {
    modal.close();
  }

  document.querySelectorAll<HTMLElement>("[data-excerpt]").forEach((card) => {
    card.addEventListener("click", () => openModal(card));
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(card);
      }
    });
  });

  closeBtn.addEventListener("click", closeModal);

  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  modal.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
