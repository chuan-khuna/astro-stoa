---
---

<dialog
  id="quote-modal"
  class="fixed inset-0 m-auto w-full max-w-2xl max-h-[90dvh] overflow-y-auto bg-page border border-rule p-[clamp(1.5rem,5vw,3.5rem)] backdrop:bg-ink/40 open:flex flex-col gap-8"
>
  <header class="flex items-start justify-between gap-4">
    <div id="modal-meta" class="flex flex-col gap-1">
      <cite id="modal-author" class="block font-body not-italic text-[0.563rem] tracking-[0.12em] uppercase text-muted"></cite>
      <span id="modal-source" class="block font-display italic text-[0.563rem] text-neutral"></span>
    </div>
    <button
      id="modal-close"
      aria-label="Close"
      class="shrink-0 text-muted hover:text-ink transition-colors duration-150 mt-0.5"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </header>

  <blockquote>
    <p id="modal-body" class="font-display italic font-light text-[clamp(1.1rem,1.8vw,1.45rem)] leading-[1.6] text-ink [overflow-wrap:anywhere] min-w-0"></p>
  </blockquote>
</dialog>

<script>
  const modal = document.getElementById("quote-modal") as HTMLDialogElement;
  const modalBody = document.getElementById("modal-body")!;
  const modalAuthor = document.getElementById("modal-author")!;
  const modalSource = document.getElementById("modal-source")!;
  const closeBtn = document.getElementById("modal-close")!;

  function openModal(card: HTMLElement) {
    const body = card.dataset.body?.trim();
    const excerpt = card.dataset.excerpt?.trim();
    modalBody.textContent = `“${body || excerpt || ""}”`;
    modalAuthor.textContent = card.dataset.author ?? "";
    modalSource.textContent = card.dataset.source ?? "";
    modal.showModal();
  }

  function closeModal() {
    modal.close();
  }

  document.querySelectorAll<HTMLElement>("[data-excerpt]").forEach((card) => {
    card.addEventListener("click", () => openModal(card));
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(card);
      }
    });
  });

  closeBtn.addEventListener("click", closeModal);

  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  modal.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
