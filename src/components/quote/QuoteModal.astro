---
// No props — modal is populated via data attributes on QuoteCard articles.
---

<dialog
  id="quote-modal"
  class="m-auto w-full max-w-2xl rounded-none border border-rule bg-paper p-[clamp(2rem,6vw,4rem)] shadow-none open:flex open:flex-col open:gap-8"
>
  <blockquote id="modal-excerpt">
    <p class="font-display italic font-light text-[clamp(1.25rem,2.5vw,2rem)] leading-[1.45] text-ink"></p>
  </blockquote>

  <footer id="modal-attribution" class="flex flex-col gap-1">
    <cite
      id="modal-author"
      class="font-body not-italic text-[0.563rem] tracking-[0.12em] uppercase text-muted"
    ></cite>
    <span
      id="modal-source"
      class="font-display italic text-[0.563rem] text-neutral"
    ></span>
  </footer>

  <div id="modal-rule" class="h-px bg-rule"></div>

  <p
    id="modal-body"
    class="font-body text-[0.875rem] leading-[1.75] text-neutral"
  ></p>

  <button
    id="modal-close"
    class="absolute top-6 right-6 font-body text-[0.563rem] tracking-[0.12em] uppercase text-muted hover:text-ink transition-colors"
    aria-label="Close quote"
  >
    Close
  </button>
</dialog>

<style>
  dialog {
    position: relative;
    transition:
      opacity 180ms ease-out,
      translate 180ms ease-out,
      overlay 180ms allow-discrete,
      display 180ms allow-discrete;
  }

  dialog[open] {
    opacity: 1;
    translate: 0 0;
  }

  @starting-style {
    dialog[open] {
      opacity: 0;
      translate: 0 0.75rem;
    }
  }

  dialog::backdrop {
    background: oklch(17% 0.012 70 / 0.45);
    opacity: 1;
    transition:
      opacity 180ms ease-out,
      overlay 180ms allow-discrete,
      display 180ms allow-discrete;
  }

  @starting-style {
    dialog[open]::backdrop {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    dialog,
    dialog::backdrop {
      transition: none;
    }
  }
</style>

<script>
  const modal = document.getElementById("quote-modal") as HTMLDialogElement;
  const modalExcerptP = modal.querySelector("#modal-excerpt p") as HTMLElement;
  const modalAuthor = document.getElementById("modal-author") as HTMLElement;
  const modalSource = document.getElementById("modal-source") as HTMLElement;
  const modalRule = document.getElementById("modal-rule") as HTMLElement;
  const modalBody = document.getElementById("modal-body") as HTMLElement;
  const modalClose = document.getElementById("modal-close") as HTMLButtonElement;

  function openModal(card: Element) {
    const excerpt = card.getAttribute("data-excerpt") ?? "";
    const body = card.getAttribute("data-body") ?? "";
    const author = card.getAttribute("data-author") ?? "";
    const source = card.getAttribute("data-source") ?? "";

    modalExcerptP.textContent = excerpt ? `“${excerpt}”` : "";
    modalAuthor.textContent = author;
    modalAuthor.style.display = author ? "" : "none";
    modalSource.textContent = source;
    modalSource.style.display = source ? "" : "none";

    const hasBody = body && body !== excerpt;
    modalRule.style.display = hasBody ? "" : "none";
    modalBody.textContent = hasBody ? body : "";
    modalBody.style.display = hasBody ? "" : "none";

    modal.showModal();
  }

  document.querySelectorAll("article[data-body]").forEach((card) => {
    card.addEventListener("click", () => openModal(card));
    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        openModal(card);
      }
    });
  });

  modalClose.addEventListener("click", () => modal.close());

  modal.addEventListener("click", (e) => {
    if (e.target === modal) modal.close();
  });
</script>
