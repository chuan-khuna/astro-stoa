---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"quotes">;
}

const { entry } = Astro.props;
---

<a
  href={`/quotes/${entry.id}`}
  class="group flex flex-col gap-6 px-[clamp(1rem,5vw,3rem)] py-12 border-r border-b border-rule hover:bg-accent/20 no-underline transition-colors duration-200"
  role="listitem"
>
  <blockquote>
    {entry.data.excerpt && (
      <p class="font-display italic font-light text-[clamp(1.1rem,1.8vw,1.45rem)] leading-[1.45] text-ink [overflow-wrap:anywhere] min-w-0 transition-colors duration-200">
        &ldquo;{entry.data.excerpt}&rdquo;
      </p>
    )}
  </blockquote>
  <footer class="flex flex-col gap-1">
    {entry.data.author && (
      <cite class="block font-body not-italic text-sm tracking-[0.12em] uppercase text-muted">
        {entry.data.author}
      </cite>
    )}
    {entry.data.source && (
      <span class="block font-display italic text-sm text-neutral">
        {entry.data.source}
      </span>
    )}
  </footer>
</a>
