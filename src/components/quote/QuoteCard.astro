---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"quotes">;
}

const { entry } = Astro.props;
---

<article
  class="group flex flex-col gap-6 px-[clamp(1rem,5vw,3rem)] py-12 border-b border-rule min-[60rem]:[&:nth-child(even)]:border-l cursor-pointer"
  role="listitem"
  tabindex="0"
  aria-haspopup="dialog"
  data-excerpt={entry.data.excerpt ?? ""}
  data-body-id={entry.id}
  data-has-body={entry.body?.trim() ? "true" : "false"}
  data-author={entry.data.author ?? ""}
  data-source={entry.data.source ?? ""}
>
  <blockquote>
    {entry.data.excerpt && (
      <p class="font-display italic font-light text-[clamp(1.1rem,1.8vw,1.45rem)] leading-[1.45] text-ink [overflow-wrap:anywhere] min-w-0 group-hover:text-neutral transition-colors duration-200">
        &ldquo;{entry.data.excerpt}&rdquo;
      </p>
    )}
  </blockquote>
  <footer class="flex flex-col gap-1">
    {entry.data.author && (
      <cite class="block font-body not-italic text-sm tracking-[0.12em] uppercase text-muted">
        {entry.data.author}
      </cite>
    )}
    {entry.data.source && (
      <span class="block font-display italic text-sm text-neutral">
        {entry.data.source}
      </span>
    )}
  </footer>
</article>

<style>
  article:focus-visible {
    outline-offset: -3px;
  }
</style>
