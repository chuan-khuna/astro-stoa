---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/data/site";
import QuoteCard from "@/components/quote/QuoteCard.astro";
import NoteCard from "@/components/note/NoteCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const allQuotes = await getCollection("quotes");
const topQuotes = allQuotes.slice(0, 10);

const allNotes = await getCollection("notes", ({ data }) => !data.draft);
allNotes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const topNotes = allNotes.slice(0, 10);
---

<Layout title={site.name}>
  <main>
    <!-- Quotes section -->
    <SectionTitle id="quotes" title="Quotes" />

    <div class="mx-4 grid grid-cols-1 min-[60rem]:grid-cols-2 border-l border-t border-rule [&>*:last-child:nth-child(odd)]:col-span-full" role="list">
      {topQuotes.map((entry) => <QuoteCard entry={entry} />)}
    </div>

    <div class="px-[clamp(1rem,5vw,3rem)] py-6">
      <a
        href="/quotes"
        class="font-body text-sm tracking-[0.12em] uppercase text-muted hover:text-ink transition-colors duration-200"
      >
        All {allQuotes.length} quotes &rarr;
      </a>
    </div>

    <!-- Notes section -->
    <SectionTitle id="notes" title="Notes" />

    {
      topNotes.length > 0 ? (
        <div class="mx-4 grid grid-cols-1 min-[60rem]:grid-cols-2 border-l border-t border-rule [&>*:last-child:nth-child(odd)]:col-span-full" role="list">
          {topNotes.map((entry) => (
            <NoteCard entry={entry} />
          ))}
        </div>
      ) : (
        <div class="px-[clamp(1rem,5vw,3rem)] py-12">
          <p class="font-display italic text-sm text-muted">No notes yet.</p>
        </div>
      )
    }

    {
      allNotes.length > 0 && (
        <div class="px-[clamp(1rem,5vw,3rem)] py-6">
          <a
            href="/notes"
            class="font-body text-sm tracking-[0.12em] uppercase text-muted hover:text-ink transition-colors duration-200"
          >
            All {allNotes.length} notes &rarr;
          </a>
        </div>
      )
    }
  </main>

</Layout>
