---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import QuoteCard from "@/components/quote/QuoteCard.astro";
import QuoteModal from "@/components/quote/QuoteModal.astro";

const entries = await getCollection("quotes");
---

<Layout title="Meditations">
  <main>
    <!-- Catalogue header -->
    <div class="px-[clamp(1rem,5vw,3rem)] py-6 border-b border-rule">
      <p class="font-body text-[0.563rem] tracking-[0.12em] uppercase text-muted">
        {entries.length} quotes &middot; curated by hand &middot; 2026
      </p>
    </div>

    <!-- Quote grid -->
    <div class="grid grid-cols-1 min-[60rem]:grid-cols-2" role="list">
      {entries.map((entry) => <QuoteCard entry={entry} />)}
    </div>
  </main>

  <QuoteModal />
</Layout>
