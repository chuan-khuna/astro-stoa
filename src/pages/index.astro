---
import Layout from '@/layouts/Layout.astro';

const quotes = [
  {
    text: "The unexamined life is not worth living.",
    author: "Socrates",
    source: "Plato, Apology",
  },
  {
    text: "We suffer more in imagination than in reality.",
    author: "Seneca",
    source: "Letters to Lucilius",
  },
  {
    text: "Begin at once to live, and count each separate day as a separate life.",
    author: "Seneca",
    source: "Letters to Lucilius",
  },
  {
    text: "He who has a why to live can bear almost any how.",
    author: "Friedrich Nietzsche",
    source: "Twilight of the Idols",
  },
  {
    text: "The present moment always will have been.",
    author: "Marcus Aurelius",
    source: "Meditations, IV.3",
  },
  {
    text: "Between stimulus and response there is a space. In that space is our power to choose our response.",
    author: "Viktor Frankl",
    source: "Man's Search for Meaning",
  },
  {
    text: "The quieter you become, the more you can hear.",
    author: "Ram Dass",
    source: "",
  },
  {
    text: "You are not a drop in the ocean. You are the entire ocean in a drop.",
    author: "Rumi",
    source: "",
  },
  {
    text: "Wherever you are, be all there.",
    author: "Jim Elliot",
    source: "",
  },
  {
    text: "What you resist persists.",
    author: "Carl Gustav Jung",
    source: "",
  },
];
---

<Layout title="Meditations">
  <main>

    <!-- Catalogue header -->
    <div class="px-[clamp(1rem,5vw,3rem)] py-6 border-b border-rule">
      <p class="font-body text-[0.563rem] tracking-[0.12em] uppercase text-muted">
        {quotes.length} quotes &middot; curated by hand &middot; 2026
      </p>
    </div>

    <!-- Quote grid (Catalogue macrostructure) -->
    <div class="grid grid-cols-1 min-[60rem]:grid-cols-2" role="list">
      {quotes.map((quote) => (
        <article
          class="flex flex-col gap-6 px-[clamp(1rem,5vw,3rem)] py-12 border-b border-rule min-[60rem]:[&:nth-child(even)]:border-l"
          role="listitem"
        >
          <blockquote>
            <p class="font-display italic font-light text-[clamp(1.1rem,1.8vw,1.45rem)] leading-[1.45] text-ink [overflow-wrap:anywhere] min-w-0">
              &ldquo;{quote.text}&rdquo;
            </p>
          </blockquote>
          <footer class="flex flex-col gap-1">
            <cite class="block font-body not-italic text-[0.563rem] tracking-[0.12em] uppercase text-muted">
              {quote.author}
            </cite>
            {quote.source && (
              <span class="block font-display italic text-[0.563rem] text-neutral">
                {quote.source}
              </span>
            )}
          </footer>
        </article>
      ))}
    </div>

  </main>
</Layout>
