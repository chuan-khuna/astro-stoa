---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/data/site";
import QuoteCard from "@/components/quote/QuoteCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const entries = await getCollection("quotes");
---

<Layout title={`Quotes — ${site.name}`}>
  <main>
    <SectionTitle title="Quotes" />

    <div class="mx-4 grid grid-cols-1 min-[60rem]:grid-cols-2 border-l border-t border-rule [&>*:last-child:nth-child(odd)]:col-span-full" role="list">
      {entries.map((entry) => <QuoteCard entry={entry} />)}
    </div>
  </main>
</Layout>
