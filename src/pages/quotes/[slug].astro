---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/data/site";

export async function getStaticPaths() {
  const entries = await getCollection("quotes");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pageTitle = entry.data.excerpt
  ? `"${entry.data.excerpt.slice(0, 60)}${entry.data.excerpt.length > 60 ? "…" : ""}" — ${site.name}`
  : `Quote — ${site.name}`;
---

<Layout title={pageTitle}>
  <main class="px-[clamp(1rem,5vw,3rem)] py-12 max-w-2xl mx-auto">

    <!-- Back link mirrors modal's top bar -->
    <div class="flex items-center justify-between mb-8">
      <a
        href="/quotes"
        class="font-body text-[0.563rem] tracking-[0.12em] uppercase text-muted hover:text-ink transition-colors duration-150 no-underline"
      >
        &larr; All quotes
      </a>
    </div>

    <article class="flex flex-col gap-8">
      <!-- Excerpt — mirrors modal blockquote -->
      <blockquote>
        <span
          aria-hidden="true"
          class="block font-display italic leading-none text-[5rem] text-accent/25 -mb-4 -ml-1 select-none"
          >&ldquo;</span
        >
        <p class="font-display italic font-light text-[clamp(1.5rem,3.2vw,2.5rem)] leading-[1.45] text-ink [overflow-wrap:anywhere] min-w-0 [text-wrap:pretty]">
          {entry.data.excerpt}
        </p>
      </blockquote>

      <!-- Attribution — mirrors modal attribution block -->
      <div class="flex flex-col gap-1.5">
        {entry.data.author && (
          <cite class="block font-body not-italic text-[0.7rem] tracking-[0.14em] uppercase text-muted">
            {entry.data.author}
          </cite>
        )}
        {entry.data.source && (
          <span class="block font-display italic text-[0.875rem] text-neutral">
            {entry.data.source}
          </span>
        )}
        {entry.data.tags && entry.data.tags.length > 0 && (
          <ul class="flex flex-wrap gap-2 mt-2" aria-label="Tags">
            {entry.data.tags.map((tag) => (
              <li class="font-body text-[0.5rem] tracking-[0.1em] uppercase text-muted border border-rule px-2 py-0.5">
                {tag}
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Full body — mirrors modal-body-wrapper -->
      {entry.body?.trim() && (
        <div class="border-t border-rule pt-6">
          <div
            class="prose max-w-[65ch]"
            style="
              --tw-prose-body: var(--color-neutral);
              --tw-prose-headings: var(--color-ink);
              --tw-prose-hr: var(--color-rule);
              --tw-prose-bullets: var(--color-neutral);
              --tw-prose-counters: var(--color-neutral);
              --tw-prose-links: var(--color-ink);
              font-family: var(--font-body);
              line-height: 1.9;
            "
          >
            <Content />
          </div>
        </div>
      )}
    </article>
  </main>
</Layout>
