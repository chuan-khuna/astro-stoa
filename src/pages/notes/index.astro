---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import NoteCard from "@/components/note/NoteCard.astro";

const entries = await getCollection("notes", ({ data }) => !data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Notes — Meditations">
  <main>
    <div class="px-[clamp(1rem,5vw,3rem)] py-6 border-b border-rule">
      <p class="font-body text-[0.563rem] tracking-[0.12em] uppercase text-muted">
        {entries.length} notes &middot; curated by hand &middot; 2026
      </p>
    </div>

    <div class="grid grid-cols-1 min-[60rem]:grid-cols-2" role="list">
      {entries.map((entry) => <NoteCard entry={entry} />)}
    </div>
  </main>
</Layout>
