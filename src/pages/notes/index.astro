---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/data/site";
import NoteCard from "@/components/note/NoteCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const entries = await getCollection("notes", ({ data }) => !data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Notes — ${site.name}`}>
  <main>
    <SectionTitle title="Notes" />

    <div class="grid grid-cols-1 min-[60rem]:grid-cols-2" role="list">
      {entries.map((entry) => <NoteCard entry={entry} />)}
    </div>
  </main>
</Layout>
