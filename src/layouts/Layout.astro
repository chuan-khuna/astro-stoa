---
import FontLoader from '@/components/FontLoader.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/data/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.name,
  description = site.description,
} = Astro.props;

const { pathname } = Astro.url;
const showScrollTop = /^\/(notes|quotes)\/[^/]+/.test(pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <FontLoader />
  </head>
  <body class="bg-paper text-ink font-body min-h-dvh">

    <!-- N6 Newspaper masthead — knobs: issue-below, size=2xl, rule=double -->
    <nav class="w-full px-[clamp(1rem,5vw,3rem)] pt-6 text-center border-t border-ink" aria-label="Site navigation">
      <div class="flex items-center justify-center gap-3 font-body text-[0.563rem] tracking-[0.14em] uppercase text-muted py-3">
        <span>{site.tagline}</span>
        <span aria-hidden="true">&middot;</span>
        <span>{site.established}</span>
      </div>
      <a
        href="/"
        class="inline-block font-display italic font-light text-[clamp(2.8rem,7vw,5rem)] tracking-[-0.025em] leading-none text-ink no-underline py-3 pb-4 transition-colors duration-[160ms] hover:text-accent"
        aria-label={site.nav.homeLabel}
      >
        {site.name}
      </a>
      <!-- FT-style section strip — single rule, active item has accent underline -->
      <div class="flex items-center gap-6 pt-0.5 pb-0 text-left border-b border-ink">
        {site.nav.sections.map(({ label, href }) => {
          const active = pathname.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'font-body text-xs tracking-[0.12em] uppercase transition-colors duration-[160ms] py-2',
                active ? 'text-ink border-b-2 border-accent -mb-px' : 'text-muted hover:text-ink',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}
      </div>
    </nav>

    <slot />

    <!-- Ft4 Dense typographic colophon — knobs: serif, single-block -->
    <Footer />

    <!-- Scroll-to-top (detail pages only) -->
    {showScrollTop && (
      <button
        id="scroll-top"
        aria-label="Scroll to top"
        class="fixed bottom-6 right-6 w-9 h-9 flex items-center justify-center border border-ink text-ink opacity-0 pointer-events-none transition-opacity duration-300 hover:bg-ink hover:text-paper focus-visible:opacity-100"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 10V2M2 6l4-4 4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
        </svg>
      </button>
    )}

    <script>
      const btn = document.getElementById('scroll-top');
      if (btn) {
        const show = () => {
          const visible = window.scrollY > 400;
          btn.style.opacity = visible ? '1' : '0';
          btn.style.pointerEvents = visible ? 'auto' : 'none';
        };
        window.addEventListener('scroll', show, { passive: true });
        btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }
    </script>

  </body>
</html>
