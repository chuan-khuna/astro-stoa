---
import FontLoader from '@/components/FontLoader.astro';
import Footer from '@/components/Footer.astro';
import Nav from '@/components/Nav.astro';
import ScrollToTop from '@/components/ScrollToTop.astro';
import { site } from '@/data/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.name,
  description = site.description,
} = Astro.props;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <FontLoader />
  </head>
  <body class="bg-paper text-ink font-body min-h-dvh">

    <div class="max-w-[90rem] mx-auto w-full border-x border-accent/25">
      <Nav />
      <slot />
      <!-- Ft4 Dense typographic colophon — knobs: serif, single-block -->
      <Footer />
    </div>

    <ScrollToTop />

  </body>
</html>
